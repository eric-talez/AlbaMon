# K-Work US — environment variables (PLACEHOLDERS ONLY — never commit real secrets)
# Copy to .env.local and fill in for local development.

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Auth + Postgres + Storage) ---
# While these stay as the placeholders below, the app runs in DEV AUTH MODE:
# a cookie-based mock session lets you pick a role (seeker/employer/admin) to
# exercise the role guards without a live Supabase project. Fill in real values
# to switch to actual Supabase auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth providers (Slice 19) ---
# Public build-time flags — NOT secrets (the real OAuth/SMS credentials live
# only in the Supabase dashboard). NEXT_PUBLIC_* values are inlined into the
# client bundle at `next build`; changing a flag requires a rebuild/redeploy.
# A method becomes clickable only when its flag is exactly "true" AND Supabase
# is configured AND the provider is set up in the Supabase dashboard —
# otherwise it renders as "setup required". See docs/AUTH_PROVIDERS.md.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_KAKAO_ENABLED=false
NEXT_PUBLIC_AUTH_NAVER_ENABLED=false
NEXT_PUBLIC_AUTH_PHONE_ENABLED=false
# Slug of the Supabase custom OIDC provider registered for Naver (the app
# passes provider "custom:<slug>"). Lowercase letters/digits/_/- only.
NEXT_PUBLIC_AUTH_NAVER_PROVIDER_ID=

# --- Stripe (test mode for development) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_FEATURED_PRICE_ID=
STRIPE_URGENT_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Email (Resend or SendGrid) ---
EMAIL_PROVIDER=dev            # dev | resend | sendgrid
EMAIL_FROM="K-Work US <no-reply@example.com>"
RESEND_API_KEY=
SENDGRID_API_KEY=

# --- Analytics (optional; DB aggregation works without these) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
